type LoginResponse {
  token: String!
  user: User!
}

input RegisterInput {
  name: String! @goField(validate: "required,max=50")
  email: String! @goField(validate: "required,max=100,email")
  password: String! @goField(validate: "required,min=8,max=255,containsany=012345678")
  confirmPassword: String!
}

extend type Mutation {
    register(input: RegisterInput!): User!
    login(email: String!, password: String!): LoginResponse!
}

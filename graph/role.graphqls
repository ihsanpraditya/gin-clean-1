extend type Query {
  role(id: ID!): Role @can(resource: "roles", action: "read")
  roles: [Role!]! @can(resource: "roles", action: "read")
}

extend type Mutation {
  createRole(name: String!): Role! @can(resource: "roles", action: "create")
  updateRole(id: ID!, name: String!): Role! @can(resource: "roles", action: "update")
  deleteRole(id: ID!): String! @can(resource: "roles", action: "delete")
}

type Role {
  id: ID!
  name: String!
}